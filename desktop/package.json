{
    "name":  "@reqloom/desktop",
    "productName":  "ReqLoom",
    "version":  "0.1.0",
    "private":  true,
    "description":  "Desktop shell for hosted ReqLoom deployments.",
    "author": "Kasra Karami <Kasra.Karami.KK@gmail.com>",
    "license": "MIT",
    "type":  "module",
    "main":  "src/main.mjs",
    "scripts":  {
                    "start":  "electron .",
                    "dist":  "electron-builder --publish never"
                },
    "build":  {
                  "appId":  "com.reqloom.desktop",
                  "productName":  "ReqLoom",
                  "asar":  true,
                  "directories":  {
                                      "output":  "dist",
                                      "buildResources":  "build"
                                  },
                  "files":  [
                                "src/**/*",
                                ".generated/**/*",
                                "package.json"
                            ],
                  "artifactName":  "ReqLoom-${version}-${os}-${arch}.${ext}",
                  "win":  {
                              "icon":  "build/icon.ico",
                              "target":  [
                                             "nsis"
                                         ],
                              "signAndEditExecutable":  false
                          },
                  "linux":  {
                                "icon":  "build/icons",
                                "target":  [
                                               "AppImage",
                                               "deb"
                                           ]
                            },
                  "mac":  {
                              "icon":  "build/icon.icns",
                              "target":  [
                                             "dmg"
                                         ]
                          },
                  "nsis":  {
                               "oneClick":  false,
                               "allowToChangeInstallationDirectory":  true
                           }
              },
    "devDependencies":  {
                            "electron":  "^35.2.0",
                            "electron-builder":  "^25.1.8"
                        }
}
